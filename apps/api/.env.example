# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_skafold?schema=public"

# JWT
JWT_SECRET="replace-me-with-a-long-random-string"
JWT_EXPIRES_IN="24h"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"

# Development admin seed
DEV_ADMIN_EMAIL="admin@saas-skafold.local"
DEV_ADMIN_PASSWORD="Admin123!"
DEV_ADMIN_NAME="Development Admin"

# Optional billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Logging
LOG_LEVEL="debug"
LOG_FILE_PATH="logs"

# Redis (for production token blacklisting)
REDIS_URL="redis://localhost:6379" 
