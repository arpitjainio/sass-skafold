{
  "name": "saas-skafold",
  "private": true,
  "license": "MIT",
  "description": "Open-source full-stack SaaS starter template with Next.js, NestJS, Prisma, and JWT auth.",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run type-check",
    "test": "turbo run test"
  },
  "devDependencies": {
    "prettier": "^3.6.0",
    "prisma": "^6.11.1",
    "turbo": "^2.5.4",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "7.8.0"
  }
}
