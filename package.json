{
  "name": "saas-skafold",
  "private": true,
  "license": "MIT",
  "description": "Open-source full-stack SaaS starter template with Next.js, NestJS, Prisma, and JWT auth.",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "db:generate": "prisma generate",
    "db:setup": "prisma migrate dev && pnpm --filter api run setup",
    "db:migrate": "prisma migrate dev",
    "db:migrate:new": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:resolve": "prisma migrate resolve",
    "db:migrate:reset": "prisma migrate reset",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run type-check",
    "test": "turbo run test",
    "postinstall": "prisma generate"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "turbo": "^2.9.18",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@prisma/client": "7.8.0"
  }
}
